# ── AWS Core ─────────────────────────────────────────────────────────────────
# For local dev (floci): http://localhost:4566
# For production: leave empty (boto3 uses real AWS endpoints)
AWS_ENDPOINT_URL=http://localhost:4566

# For local dev: use "test" / "test"
# For production: use real IAM credentials
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# ── S3 ───────────────────────────────────────────────────────────────────────
S3_BUCKET_NAME=resume-ranker-dev-storage

# ── DynamoDB ─────────────────────────────────────────────────────────────────
DYNAMODB_TABLE_NAME=ResumePlatform

# ── App ──────────────────────────────────────────────────────────────────────
# development | production
ENVIRONMENT=development
LOG_LEVEL=DEBUG
